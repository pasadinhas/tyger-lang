extern fn printf(fmt: ptr, ...) -> i32;

struct Point {
  x: f64;
  y: f64;
}

fn print_point(p: Point) -> i64 {
  printf("(%g, %g)\n", p.x, p.y);
  return 0;
}

fn scale(mut p: Point, factor: f64) -> i64 {
  return 0;
}

fn main() -> i32 {
  let p = Point{x=3.0, y=4.0};
  print_point(p);

  let mut q = Point{x=1.0, y=2.0};
  scale(q, 2.0);
  print_point(q);
}
